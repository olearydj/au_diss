@incollection{kirka2020,
  title = {Analysis of {{Data Streams}} for {{Qualification}} and {{Certification}} of {{Inconel 738LC Airfoils Processed}} through {{Electron Beam Melting}}},
  booktitle = {Structural {{Integrity}} of {{Additive Manufactured Materials}} and {{Parts}}},
  author = {Kirka, Michael and Rose, Derek and Halsey, William and Ziabari, Amirkoushyar and Paquit, Vincent and Ryan, Daniel and Brackman, Paul},
