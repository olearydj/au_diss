  file = {/Users/djo/Box Sync/zotero/dissertation/ar-metrics-manuf/Tang et al. - 2003 - Comparative effectiveness of augmented reality in .pdf}
}

@article{tao2017digit,
  title = {Digital {{Twin Shop-Floor}}: {{A New Shop-Floor Paradigm Towards Smart Manufacturing}}},
